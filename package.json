{
  "name": "portfolio-next",
  "description": "My Portfolio Site",
  "author": {
    "email": "coreyburns@outlook.com",
    "name": "Corey Burns",
    "url": "https://coreyburns.dev"
  },
  "version": "1.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/corey-burns-dev/portfolio-next"
  },
  "license": "MIT",
  "packageManager": "bun@1.3.1",
  "keywords": [
    "astro",
    "tailwindcss",
    "portfolio",
    "frontend",
    "full-stack"
  ],
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "deploy": "scripts/deploy-pages.sh",
    "deploy:prod": "scripts/deploy-pages.sh main",
    "cf:status": "../scripts/cf-portfolio.sh status portfolio",
    "preview": "astro preview",
    "prepare": "husky",
    "type-check": "tsc --pretty --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "lint-staged": "lint-staged"
  },
  "lint-staged": {
    "ignore": [
      ".vscode/**"
    ],
    "*.{js,jsx,ts,tsx,json}": [
      "biome check --write --files"
    ]
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@astrojs/tailwind": "^6.0.2",
    "@biomejs/biome": "^2.4.8",
    "@types/node": "^25.5.0",
    "astro": "^6.0.6",
    "autoprefixer": "^10.4.27",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "wrangler": "^4.75.0"
  }
}
