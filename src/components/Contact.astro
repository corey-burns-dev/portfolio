---
import { socials } from '../data/socials';

const icon = {
  email: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8"/><path d="M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
  github: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5A12 12 0 0 0 0 12.7c0 5.42 3.44 10 8.2 11.62.6.12.82-.26.82-.58v-2.1c-3.34.74-4.03-1.66-4.03-1.66-.55-1.43-1.33-1.81-1.33-1.81-1.08-.76.08-.75.08-.75 1.2.08 1.83 1.27 1.83 1.27 1.06 1.88 2.8 1.33 3.48 1.02.1-.79.42-1.33.76-1.64-2.66-.31-5.46-1.37-5.46-6.1 0-1.35.46-2.46 1.22-3.33-.12-.31-.53-1.57.12-3.27 0 0 1-.33 3.3 1.26a11.1 11.1 0 0 1 6 0c2.3-1.59 3.3-1.26 3.3-1.26.65 1.7.24 2.96.12 3.27.76.87 1.22 1.98 1.22 3.33 0 4.74-2.8 5.78-5.48 6.08.43.38.82 1.12.82 2.26v3.35c0 .32.21.7.82.58 4.76-1.62 8.2-6.2 8.2-11.62A12 12 0 0 0 12 .5z"/></svg>`,
  linkedin: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.45 20.45h-3.55v-5.56c0-1.33-.03-3.04-1.85-3.04-1.85 0-2.13 1.45-2.13 2.95v5.65H9.38V9h3.4v1.56h.05c.47-.9 1.62-1.85 3.34-1.85 3.57 0 4.23 2.35 4.23 5.4v6.34zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.56V9h3.56v11.45zM22.23 0H1.77C.79 0 0 .78 0 1.74v20.52C0 23.22.79 24 1.77 24h20.46C23.2 24 24 23.22 24 22.26V1.74C24 .78 23.2 0 22.23 0z"/></svg>`,
};
---

<section
  id='contact'
  class='relative'
>
  <div class='mx-auto max-w-7xl px-6 pb-24'>
    <div class='glass-strong rounded-[2rem] p-6 sm:p-10 text-center'>
      <p class='text-[11px] uppercase tracking-[0.4em] text-slate-500 font-extrabold'>
        Let’s build
      </p>
      <h2 class='mt-3 font-heading fluid-h2 font-black text-slate-800'>Want to work together?</h2>
      <p class='mt-4 fluid-body text-slate-600 max-w-prose mx-auto'>
        Reach out for freelance, full-time, or collaboration opportunities. I respond quickly and
        love new challenges.
      </p>
      <div class='mt-6 flex flex-wrap items-center justify-center gap-3'>
        <a
          class='rounded-full bg-teal-700 px-5 py-2 fluid-ui font-extrabold text-white shadow hover:-translate-y-0.5 transition-transform'
          href='mailto:coreyburns@outlook.com'
        >
          Email Me
        </a>
        {
          socials
            .filter(item => item.title !== 'Email')
            .map(item => (
              <a
                class='inline-flex items-center gap-2 rounded-full bg-white/80 px-4 py-2 fluid-ui font-extrabold text-slate-800 border border-white/70 hover:-translate-y-0.5 transition-transform'
                href={item.url}
                target='_blank'
                rel='noreferrer'
              >
                <span
                  class='h-4 w-4'
                  set:html={icon[item.icon as keyof typeof icon]}
                />
                {item.title}
              </a>
            ))
        }
      </div>
    </div>
  </div>
</section>
