---
import { Image } from 'astro:assets';
import bgImage from '../assets/bg/leaves.webp';
import { aboutMe, randomFacts } from '../data/about';
import SectionHeading from './SectionHeading.astro';
---

<section
  id='about'
  class='relative'
>
  <div class='absolute inset-0 -z-10'>
    <Image
      src={bgImage}
      alt=''
      class='h-full w-full object-cover opacity-20'
      loading='lazy'
      widths={[480, 640, 960]}
      sizes='100vw'
      quality={50}
    />
  </div>
  <SectionHeading title='About' />
  <div class='mx-auto max-w-7xl px-6 pb-24 grid gap-8 lg:grid-cols-2'>
    <div
      class='glass rounded-2xl p-6 sm:p-8 hover:-translate-y-1 transition-transform relative overflow-hidden'
    >
      <span
        class='absolute top-4 right-4 inline-flex h-9 w-9 items-center justify-center rounded-full bg-white/80 border border-white/70 text-slate-600 shadow-sm'
      >
        <svg
          viewBox='0 0 24 24'
          aria-hidden='true'
          class='h-4 w-4'
        >
          <path
            d='M12 3.2c-4.85 0-8.8 3.95-8.8 8.8 0 4.85 3.95 8.8 8.8 8.8 4.85 0 8.8-3.95 8.8-8.8 0-4.85-3.95-8.8-8.8-8.8Zm0 4.4a4.4 4.4 0 1 1 0 8.8 4.4 4.4 0 0 1 0-8.8Z'
            fill='currentColor'
            opacity='0.9'
          ></path>
          <path
            d='M17.8 8.4c-.5-.9-1.4-1.6-2.5-1.6-1 0-1.9.5-2.4 1.3'
            fill='none'
            stroke='white'
            stroke-width='1.4'
            stroke-linecap='round'
            opacity='0.9'
          ></path>
        </svg>
      </span>
      <div class='flex items-center gap-3'>
        <span
          class='inline-flex items-center rounded-full border border-white/70 bg-gradient-to-r from-amber-200 via-rose-200 to-sky-200 px-3 py-1 text-[11px] font-black uppercase tracking-[0.35em] text-slate-700 shadow-sm'
        >
          Radar
        </span>
        <div class='h-px flex-1 bg-gradient-to-r from-slate-300/70 via-slate-200/40 to-transparent'>
        </div>
      </div>
      <h3 class='mt-3 font-heading fluid-h3 font-black text-slate-800'>
        <span
          class='bg-gradient-to-r from-slate-900 via-slate-700 to-slate-500 bg-clip-text text-transparent'
        >
          {randomFacts.title}
        </span>
      </h3>
      <ul class='mt-4 space-y-2 fluid-body text-slate-600 measure'>
        {randomFacts.facts.map(fact => <li>{fact.title}</li>)}
      </ul>
    </div>
    <div class='glass rounded-2xl p-6 sm:p-8 hover:-translate-y-1 transition-transform'>
      <div class='flex items-center gap-3'>
        <span
          class='inline-flex items-center rounded-full border border-white/70 bg-gradient-to-r from-emerald-200 via-teal-200 to-cyan-200 px-3 py-1 text-[11px] font-black uppercase tracking-[0.35em] text-slate-700 shadow-sm'
        >
          Notes
        </span>
        <div class='h-px flex-1 bg-gradient-to-r from-slate-300/70 via-slate-200/40 to-transparent'>
        </div>
      </div>
      <h3 class='mt-3 font-heading fluid-h3 font-black text-slate-800'>
        <span
          class='bg-gradient-to-r from-slate-900 via-slate-700 to-slate-500 bg-clip-text text-transparent'
        >
          {aboutMe.title}
        </span>
      </h3>
      <ul class='mt-4 space-y-2 fluid-body text-slate-600 measure'>
        {aboutMe.excerpt.map(p => <li>{p.text}</li>)}
      </ul>
    </div>
  </div>
</section>
