---
import { sections } from '../data/sections';
import { socials } from '../data/socials';
---

<header
  class='fixed top-0 left-0 right-0 z-40 bg-white/80 backdrop-blur-xl border-b border-white/40'
>
  <nav class='mx-auto flex h-12 items-center px-4 sm:px-8 max-w-7xl'>
    <a
      href='#home'
      class='fluid-ui font-extrabold tracking-wide text-slate-800'
    >
      Corey Burns
    </a>
    <div class='flex-1 flex items-center justify-center'>
      <div class='sm:hidden text-[11px] font-bold tracking-[0.25em] uppercase text-slate-600'>
        <span
          class='italic text-teal-500 relative'
          data-current-section
        ></span>
      </div>
      <ul
        class='hidden sm:flex items-center gap-6 fluid-caption font-bold tracking-[0.25em] uppercase text-slate-600'
      >
        {
          sections.map(sec => (
            <li>
              <a
                class='nav-link relative hover:text-teal-500 transition-colors'
                data-section-link
                href={`#${sec.id}`}
              >
                {sec.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
    <details
      class='relative group hidden sm:block'
      data-links-menu
    >
      <summary
        class='list-none cursor-pointer rounded-full bg-teal-600 px-3 py-1 text-[10px] font-extrabold uppercase tracking-[0.25em] text-white shadow-md shadow-teal-500/30 border border-teal-400/40 hover:-translate-y-0.5 transition-transform cta-pulse'
      >
        Links
      </summary>
      <div class='absolute right-0 mt-2 w-40 rounded-2xl glass p-3'>
        <ul class='space-y-2 fluid-caption font-bold text-slate-700'>
          {
            socials.map(item => (
              <li>
                <a
                  class='flex items-center gap-2 hover:text-teal-500 transition-colors'
                  href={item.url}
                  target='_blank'
                  rel='noreferrer'
                >
                  <span class='inline-flex h-4 w-4 items-center justify-center text-slate-500'>
                    {item.icon === 'email' && (
                      <svg
                        viewBox='0 0 24 24'
                        aria-hidden='true'
                        class='h-4 w-4'
                      >
                        <path
                          d='M4 6h16a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2Z'
                          fill='none'
                          stroke='currentColor'
                          stroke-width='1.6'
                          stroke-linecap='round'
                          stroke-linejoin='round'
                        />
                        <path
                          d='m22 8-8.5 6.2a3 3 0 0 1-3 0L2 8'
                          fill='none'
                          stroke='currentColor'
                          stroke-width='1.6'
                          stroke-linecap='round'
                          stroke-linejoin='round'
                        />
                      </svg>
                    )}
                    {item.icon === 'github' && (
                      <svg
                        viewBox='0 0 24 24'
                        aria-hidden='true'
                        class='h-4 w-4'
                      >
                        <path
                          d='M12 2c-5.52 0-10 4.58-10 10.23 0 4.52 2.87 8.36 6.85 9.71.5.1.68-.22.68-.48 0-.24-.01-.88-.01-1.73-2.79.62-3.38-1.38-3.38-1.38-.46-1.18-1.12-1.49-1.12-1.49-.92-.64.07-.63.07-.63 1.02.07 1.56 1.07 1.56 1.07.9 1.57 2.36 1.12 2.94.86.09-.67.35-1.12.63-1.38-2.23-.26-4.58-1.14-4.58-5.07 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.7 0 0 .84-.28 2.75 1.05a9.2 9.2 0 0 1 5 0C16.65 6.88 17.5 7.16 17.5 7.16c.55 1.4.2 2.44.1 2.7.64.72 1.03 1.63 1.03 2.75 0 3.94-2.36 4.8-4.6 5.06.36.32.69.95.69 1.92 0 1.39-.01 2.5-.01 2.84 0 .27.18.59.69.48 3.97-1.35 6.83-5.19 6.83-9.71C22 6.58 17.52 2 12 2Z'
                          fill='currentColor'
                        />
                      </svg>
                    )}
                    {item.icon === 'linkedin' && (
                      <svg
                        viewBox='0 0 24 24'
                        aria-hidden='true'
                        class='h-4 w-4'
                      >
                        <path
                          d='M4.98 3.5a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5Zm-1.5 7h3v10h-3v-10Zm6.5 0h2.9v1.36h.04c.4-.76 1.38-1.56 2.84-1.56 3.04 0 3.6 2.02 3.6 4.64v5.56h-3v-4.93c0-1.18-.02-2.7-1.64-2.7-1.64 0-1.9 1.28-1.9 2.61v5.02h-3v-10Z'
                          fill='currentColor'
                        />
                      </svg>
                    )}
                  </span>
                  {item.title}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </details>
    <details
      class='relative sm:hidden'
      data-mobile-menu
    >
      <summary
        class='list-none cursor-pointer rounded-full bg-white/80 px-3 py-1 text-[11px] font-extrabold uppercase tracking-[0.25em] text-slate-600 border border-white/70'
      >
        Menu
      </summary>
      <div class='absolute right-0 mt-2 w-56 rounded-2xl glass p-4'>
        <ul
          class='space-y-3 fluid-caption font-extrabold uppercase tracking-[0.2em] text-slate-700'
        >
          {
            sections.map(sec => (
              <li>
                <a
                  class='hover:text-teal-500 transition-colors'
                  href={`#${sec.id}`}
                  data-section-link
                  data-close-mobile-menu
                >
                  {sec.label}
                </a>
              </li>
            ))
          }
        </ul>
        <div class='mt-4 border-t border-white/70 pt-3'>
          <div class='text-[10px] uppercase tracking-[0.3em] text-slate-400 font-extrabold'>
            Links
          </div>
          <ul class='mt-2 space-y-2 fluid-caption font-bold text-slate-700'>
            {
              socials.map(item => (
                <li>
                  <a
                    class='flex items-center gap-2 hover:text-teal-500 transition-colors'
                    href={item.url}
                    target='_blank'
                    rel='noreferrer'
                    data-close-mobile-menu
                  >
                    <span class='inline-flex h-4 w-4 items-center justify-center text-slate-500'>
                      {item.icon === 'email' && (
                        <svg
                          viewBox='0 0 24 24'
                          aria-hidden='true'
                          class='h-4 w-4'
                        >
                          <path
                            d='M4 6h16a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2Z'
                            fill='none'
                            stroke='currentColor'
                            stroke-width='1.6'
                            stroke-linecap='round'
                            stroke-linejoin='round'
                          />
                          <path
                            d='m22 8-8.5 6.2a3 3 0 0 1-3 0L2 8'
                            fill='none'
                            stroke='currentColor'
                            stroke-width='1.6'
                            stroke-linecap='round'
                            stroke-linejoin='round'
                          />
                        </svg>
                      )}
                      {item.icon === 'github' && (
                        <svg
                          viewBox='0 0 24 24'
                          aria-hidden='true'
                          class='h-4 w-4'
                        >
                          <path
                            d='M12 2c-5.52 0-10 4.58-10 10.23 0 4.52 2.87 8.36 6.85 9.71.5.1.68-.22.68-.48 0-.24-.01-.88-.01-1.73-2.79.62-3.38-1.38-3.38-1.38-.46-1.18-1.12-1.49-1.12-1.49-.92-.64.07-.63.07-.63 1.02.07 1.56 1.07 1.56 1.07.9 1.57 2.36 1.12 2.94.86.09-.67.35-1.12.63-1.38-2.23-.26-4.58-1.14-4.58-5.07 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.7 0 0 .84-.28 2.75 1.05a9.2 9.2 0 0 1 5 0C16.65 6.88 17.5 7.16 17.5 7.16c.55 1.4.2 2.44.1 2.7.64.72 1.03 1.63 1.03 2.75 0 3.94-2.36 4.8-4.6 5.06.36.32.69.95.69 1.92 0 1.39-.01 2.5-.01 2.84 0 .27.18.59.69.48 3.97-1.35 6.83-5.19 6.83-9.71C22 6.58 17.52 2 12 2Z'
                            fill='currentColor'
                          />
                        </svg>
                      )}
                      {item.icon === 'linkedin' && (
                        <svg
                          viewBox='0 0 24 24'
                          aria-hidden='true'
                          class='h-4 w-4'
                        >
                          <path
                            d='M4.98 3.5a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5Zm-1.5 7h3v10h-3v-10Zm6.5 0h2.9v1.36h.04c.4-.76 1.38-1.56 2.84-1.56 3.04 0 3.6 2.02 3.6 4.64v5.56h-3v-4.93c0-1.18-.02-2.7-1.64-2.7-1.64 0-1.9 1.28-1.9 2.61v5.02h-3v-10Z'
                            fill='currentColor'
                          />
                        </svg>
                      )}
                    </span>
                    {item.title}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </details>
  </nav>
</header>

<script>
  const mobileMenu = document.querySelector('[data-mobile-menu]');
  const linksMenu = document.querySelector('[data-links-menu]');
  if (mobileMenu) {
    const closeMenu = () => {
      mobileMenu.removeAttribute('open');
    };

    mobileMenu.querySelectorAll('[data-close-mobile-menu]').forEach(link => {
      link.addEventListener('click', closeMenu);
    });
  }
  if (linksMenu) {
    const closeLinks = () => {
      linksMenu.removeAttribute('open');
    };
    const linksSummary = linksMenu.querySelector('summary');
    const stopPulse = () => {
      linksSummary?.classList.remove('cta-pulse');
      linksSummary?.removeEventListener('click', stopPulse);
    };
    linksSummary?.addEventListener('click', stopPulse);
    window.addEventListener('scroll', closeLinks, { passive: true });
    window.addEventListener('resize', closeLinks);
  }
</script>
